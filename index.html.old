<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="CEAA Kpalimé : centre d'enseignement artisanal et artistique - cuisine, batik, couture, sculpture."
    />
    <meta
      name="keywords"
      content="CEAA, Kpalimé, artisanat, batik, couture, sculpture, cuisine, formation"
    />
    <meta
      property="og:title"
      content="CEAA - Centre d'Enseignement Artisanal et Artistique"
    />
    <meta
      property="og:description"
      content="Découvrez les créations artisanales et rejoignez notre communauté de clients fidèles."
    />
    <meta
      property="og:image"
      content="https://<votre-site>.github.io/vitrine-ceaa/img/hero.png"
    />
    <meta property="og:type" content="website" />
    <title>CEAA - Centre d'Enseignement Artisanal et Artistique</title>
    <link rel="stylesheet" href="css/styles.css" />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "CEAA",
        "url": "https://<votre-site>.github.io/vitrine-ceaa",
        "description": "Centre d'enseignement artisanal et artistique de Kpalimé",
        "sameAs": []
      }
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container nav-wrap">
        <div class="logo">CEAA</div>
        <nav>
          <a href="index.html">Accueil</a>
          <a href="pages/formations.html">Formations</a>
          <a href="pages/actualites.html">Actualités</a>
          <a href="pages/contact.html">Contact</a>
        </nav>
      </div>
      <section
        class="hero"
        tabindex="0"
        aria-label="Carrousel des départements de formation"
      >
        <!-- <img
          class="hero-dept-image"
          id="hero-dept-image"
          src="img/cuisine2.png"
          data-fallback-src="img/icone/icon-cuisine.svg"
          alt="Icône du département Cuisine"
        /> -->

        <div class="hero-content" id="hero-content">
          <h1 id="hero-title">Cuisine & saveurs de Kpalimé et d'ailleurs</h1>
          <p id="hero-description">
            Techniques culinaires, hygiène et recettes locales pour créer des
            plats d’exception.
          </p>
          <a
            class="cta"
            id="hero-cta"
            href="pages/formations.html"
            aria-label="Découvrir les formations du CEAA"
            >Découvrez nos formations</a
          >
        </div>

        <!-- <div class="hero-slider-controls" aria-hidden="false">
          <button
            type="button"
            class="hero-nav-btn"
            id="hero-prev"
            aria-label="Slide précédente"
          >
            ‹
          </button>
          <div
            class="hero-dots"
            id="hero-dots"
            aria-label="Choisir un département de formation"
          ></div>
          <button
            type="button"
            class="hero-nav-btn"
            id="hero-next"
            aria-label="Slide suivante"
          >
            ›
          </button>
        </div> -->
      </section>
    </header>

    <main class="container">
      <section class="block two-col">
        <div class="block-item">
          <h3>Mot du directeur</h3>
          <p>
            Bienvenue au CEAA, centre d'excellence où cuisine, batik, couture et
            sculpture se rencontrent. Nous formons les talents et exposons des
            œuvres d’exception.
          </p>
          <a href="pages/formateurs.html" class="small-btn"
            >Rencontrez nos formateurs</a
          >
        </div>
        <div class="block-item">
          <img src="img/icone/icon-agent.svg" alt="Icone directeur CEAA" />
        </div>
      </section>

      <section id="formations" class="block">
        <h2>Nos formations</h2>
        <div class="cards">
          <article class="card">
            <img src="img/icone/icon-cuisine.svg" alt="Cuisine CEAA" />
            <h4>Cuisine</h4>
            <p>Arts culinaires locaux et enseignements techniques.</p>
          </article>
          <article class="card">
            <img src="img/icone/icon-batik.svg" alt="Batik CEAA" />
            <h4>Batik</h4>
            <p>Tissus artisanaux teints à la main.</p>
          </article>
          <article class="card">
            <img src="img/icone/icon-couture.svg" alt="Couture CEAA" />
            <h4>Couture</h4>
            <p>Mode, stylisme et couture traditionnelle.</p>
          </article>
          <article class="card">
            <img src="img/icone/icon-sculpture.svg" alt="Sculpture CEAA" />
            <h4>Sculpture</h4>
            <p>Créations sur bois, pierre et métal.</p>
          </article>
          <article class="card">
            <img src="img/icone/icon-tissage.svg" alt="Tissage CEAA" />
            <h4>Tissage</h4>
            <p>Techniques de tissage traditionnelles et modernes.</p>
          </article>
          <article class="card">
            <img src="img/icone/icon-peinture.svg" alt="Peinture CEAA" />
            <h4>Peinture</h4>
            <p>Méthodes de peinture sur toile, mur et matériaux artisanaux.</p>
          </article>
          <article class="card">
            <img src="img/icone/icon-poterie.svg" alt="Poterie CEAA" />
            <h4>Poterie</h4>
            <p>
              Travail de l’argile, modelage et cuisson d’objets utilitaires et
              décoratifs.
            </p>
          </article>
          <article class="card">
            <img src="img/icone/icon-musique.svg" alt="Musique CEAA" />
            <h4>Musique</h4>
            <p>
              Atelier chant et percussions pour sons traditionnels et modernes.
            </p>
          </article>
        </div>
        <a href="pages/formations.html" class="small-btn"
          >Voir la page des formations</a
        >
      </section>

      <section id="produits" class="block">
        <h2>Produits phares</h2>
        <div class="items">
          <article>
            <img
              src="img/icone/icon-batik-royal.svg"
              alt="Tapisserie Batik Royal"
            />
            <h4>Tapisserie Batik Royal</h4>
            <p>Motifs traditionnels tissés et teints par nos apprentis.</p>
          </article>
          <article>
            <img
              src="img/icone/icon-assortiment-culinaire.svg"
              alt="Assortiment culinaire Kpalimé"
            />
            <h4>Assortiment culinaire « Kpalimé»</h4>
            <p>Box dégustation de saveurs artisanales locales.</p>
          </article>
          <article>
            <img
              src="img/icone/icon-ensemble-couture.svg"
              alt="Ensemble couture moderne"
            />
            <h4>Ensemble couture moderne</h4>
            <p>Vêtements sur mesure inspirés des motifs régionaux.</p>
          </article>
        </div>
      </section>

      <section id="meilleures-ventes" class="block">
        <h2>Meilleures ventes</h2>
        <p>
          Découvrez nos produits les plus populaires, plébiscités par nos
          clients et visiteurs.
        </p>
        <div class="items">
          <article>
            <img
              src="img/icone/icon-batik-royal.svg"
              alt="Tapisserie Batik Royal"
            />
            <h4>Tapisserie Batik Royal</h4>
            <p>Produit le plus demandé par les visiteurs internationaux.</p>
          </article>
          <article>
            <img
              src="img/icone/icon-assortiment-culinaire.svg"
              alt="Assortiment culinaire Kpalimé"
            />
            <h4>Assortiment culinaire « Kpalimé »</h4>
            <p>Top vente depuis 2025 pour cadeau d’entreprise et événements.</p>
          </article>
          <article>
            <img
              src="img/icone/icon-ensemble-couture.svg"
              alt="Ensemble couture moderne"
            />
            <h4>Ensemble couture moderne</h4>
            <p>Meilleure vente dans la catégorie mode régionale.</p>
          </article>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>CEAA - Centre d'enseignement artisanal et artistique de Kpalimé</p>
        <div class="footer-links">
          <a href="#formations">Formations</a>
          <a href="#produits">Produits</a>
          <a href="pages/formateurs.html">Formateurs</a>
        </div>
      </div>
    </footer>

    <script>
      (function () {
        const heroEl = document.querySelector(".hero");
        const titleEl = document.getElementById("hero-title");
        const descEl = document.getElementById("hero-description");
        const ctaEl = document.getElementById("hero-cta");
        const dotsEl = document.getElementById("hero-dots");

        const slides = [
          {
            title: "Cuisine & saveurs de Kpalimé et d'ailleurs",
            description:
              "Techniques culinaires, hygiène et recettes locales pour créer des plats d’exception.",
            bg: "img/cuisine2.png",
            grad1: "rgba(196, 87, 47, 0.68)",
            grad2: "rgba(125, 60, 31, 0.28)",
          },
          {
            title: "Batik : motifs & teinture à la main",
            description:
              "Création et teinture de tissus, entre motifs traditionnels et inspirations contemporaines.",
            bg: "img/pagne2.jpg",
            grad1: "rgba(87, 98, 196, 0.65)",
            grad2: "rgba(61, 44, 125, 0.26)",
          },
          {
            title: "Couture : design et mode éthique",
            description:
              "Patronage, confection et stylisme pour des créations solides et respectueuses des savoir-faire.",
            bg: null,
            grad1: "rgba(92, 158, 122, 0.62)",
            grad2: "rgba(35, 92, 62, 0.25)",
          },
          {
            title: "Sculpture : bois, pierre et métal",
            description:
              "Modelage et gravure pour créer des œuvres durables et expressives.",
            bg: null,
            grad1: "rgba(168, 122, 60, 0.62)",
            grad2: "rgba(95, 60, 25, 0.26)",
          },
          {
            title: "Tissage : textiles et créations innovantes",
            description:
              "Techniques de tissage traditionnelles et motifs modernes pour produire des pièces uniques.",
            bg: null,
            grad1: "rgba(180, 104, 150, 0.62)",
            grad2: "rgba(115, 50, 87, 0.25)",
          },
          {
            title: "Peinture : couleurs & inspiration locale",
            description:
              "Atelier de peinture et peinture décorative inspirée de l’art et de la culture de la région.",
            bg: "img/peinture.png",
            grad1: "rgba(62, 114, 154, 0.62)",
            grad2: "rgba(35, 70, 104, 0.25)",
          },
          {
            title: "Poterie : modelage & cuisson",
            description:
              "Modélisation de l’argile, cuisson en four et création d’objets en céramique.",
            bg: null,
            grad1: "rgba(214, 134, 82, 0.62)",
            grad2: "rgba(125, 75, 35, 0.26)",
          },
          {
            title: "Musique : rythmes & culture",
            description:
              "Atelier chant, percussions et rythmes locaux pour une expérience culturelle vivante.",
            bg: null,
            grad1: "rgba(120, 170, 210, 0.62)",
            grad2: "rgba(45, 95, 140, 0.25)",
          },
        ];

        let currentIndex = 0;
        let timer = null;
        let isPaused = false;

        function setGrad(grad1, grad2) {
          heroEl.style.setProperty("--hero-grad-1", grad1);
          heroEl.style.setProperty("--hero-grad-2", grad2);
        }

        function setHeroBg(bgUrl) {
          if (!bgUrl) {
            heroEl.style.setProperty("--hero-bg-image", "none");
            return;
          }

          // Anti-course: on ne garde que la dernière demande
          const reqId = (setHeroBg._reqId = (setHeroBg._reqId || 0) + 1);
          const testImg = new Image();
          testImg.onload = function () {
            if (reqId !== setHeroBg._reqId) return;
            heroEl.style.setProperty("--hero-bg-image", 'url("' + bgUrl + '")');
          };
          testImg.onerror = function () {
            if (reqId !== setHeroBg._reqId) return;
            heroEl.style.setProperty("--hero-bg-image", "none");
          };
          testImg.src = bgUrl;
        }

        function updateDots() {
          const dots = Array.from(dotsEl.children);
          dots.forEach((dot, i) => {
            dot.classList.toggle("is-active", i === currentIndex);
            dot.setAttribute(
              "aria-current",
              i === currentIndex ? "true" : "false",
            );
          });
        }

        function renderDots() {
          dotsEl.innerHTML = "";
          slides.forEach((_, i) => {
            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = "hero-dot";
            btn.setAttribute("aria-label", "Aller au slide " + (i + 1));
            btn.addEventListener("click", function () {
              goTo(i);
            });
            dotsEl.appendChild(btn);
          });
          updateDots();
        }

        function goTo(index) {
          const next =
            ((index % slides.length) + slides.length) % slides.length;

          // Animation légère de sortie/entrée
          titleEl.closest(".hero-content").classList.add("is-fading");

          window.setTimeout(function () {
            currentIndex = next;
            const s = slides[currentIndex];

            titleEl.textContent = s.title;
            descEl.textContent = s.description;
            ctaEl.setAttribute("href", "pages/formations.html");
            
            // Appliquer l'image de fond si elle existe
            if (s.bg) {
              setHeroBg(s.bg);
            } else {
              setHeroBg(null);
            }
            
            setGrad(s.grad1, s.grad2);
            updateDots();

            titleEl.closest(".hero-content").classList.remove("is-fading");
          }, 220);
        }

        function next() {
          if (!isPaused) {
            goTo(currentIndex + 1);
          }
        }

        function prev() {
          if (!isPaused) {
            goTo(currentIndex - 1);
          }
        }

        function startAuto() {
          const reduced =
            window.matchMedia &&
            window.matchMedia("(prefers-reduced-motion: reduce)").matches;

          if (reduced || isPaused) return;

          stopAuto();
          timer = window.setInterval(next, 6500);
        }

        function stopAuto() {
          if (timer) {
            window.clearInterval(timer);
            timer = null;
          }
        }

        // Pause au survol de la souris
        function pauseAuto() {
          isPaused = true;
          stopAuto();
        }

        function resumeAuto() {
          isPaused = false;
          startAuto();
        }

        // Événements de pause/reprise au survol
        heroEl.addEventListener("mouseenter", pauseAuto);
        heroEl.addEventListener("mouseleave", resumeAuto);
        
        // Pause également quand on focus sur des éléments interactifs
        heroEl.addEventListener("focusin", pauseAuto);
        heroEl.addEventListener("focusout", resumeAuto);

        // Navigation clavier (flèches gauche/droite)
        heroEl.addEventListener("keydown", function (e) {
          if (e.key === "ArrowLeft") {
            e.preventDefault();
            if (!isPaused) {
              prev();
            }
          }
          if (e.key === "ArrowRight") {
            e.preventDefault();
            if (!isPaused) {
              next();
            }
          }
        });

        // Initialisation
        renderDots();
        setGrad(slides[0].grad1, slides[0].grad2);
        setHeroBg(slides[0].bg);
        goTo(0);
        startAuto();
      })();
    </script>
  </body>
</html>
